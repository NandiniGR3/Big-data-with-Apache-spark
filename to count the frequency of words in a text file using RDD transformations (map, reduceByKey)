import re
from pyspark.sql import SparkSession
from nltk.corpus import stopwords
import nltk
import pandas as pd # Import pandas here

try:
    stopwords.words('english')
except LookupError:
    nltk.download('stopwords')

# Create Spark Session
spark = SparkSession.builder \
    .appName("WordFrequencyWithNLP") \
    .master("local[*]") \
    .getOrCreate()

sc = spark.sparkContext

try:
    rdd = sc.textFile("sample.txt")
except Exception as e:
    print(f"Error loading sample.txt: {e}. Please ensure 'sample.txt' is uploaded or provide a path to your text file.")
    # Fallback to a dummy RDD for demonstration if file not found
    rdd = sc.parallelize(["This is a sample text file.", "It contains some words for demonstration."])

# Get English stopwords
english_stopwords = set(stopwords.words('english'))

# -------------------------
# NLP Preprocessing Steps
# -------------------------

# Convert text to lowercase
rdd_lower = rdd.map(lambda x: x.lower())

# Remove punctuation and special characters
rdd_clean = rdd_lower.map(
    lambda x: re.sub(r'[^a-zA-Z\s]', '', x) # Keep only letters and spaces
)

# Remove extra spaces and split lines into words
words = rdd_clean.flatMap(lambda x: x.strip().split(" "))

# Remove empty words and filter out stopwords
words_filtered = words.filter(lambda x: x.strip() != "" and x not in english_stopwords)

# -------------------------
# Word Frequency Count
# -------------------------

word_count = words_filtered.map(
    lambda word: (word, 1)
).reduceByKey(
    lambda a, b: a + b
)

# Sort by frequency (descending)
result = word_count.sortBy(
    lambda x: x[1],
    ascending=False
)

# Display Results and collect into Pandas DataFrame
print("Word Frequencies:")
collected_results = result.collect()
for word, count in collected_results:
    print(f"{word} : {count}")

# Convert collected results to a Pandas DataFrame for plotting
df_word_freq = pd.DataFrame(collected_results, columns=['word', 'count'])

